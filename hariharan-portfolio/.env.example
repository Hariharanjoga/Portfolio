# ============================================================
#  Copy this file to ".env.local" and fill in your real keys.
#  .env.local is gitignored — never commit real secrets.
# ============================================================

# --- LLM brain for the "Ask my AI" chat (NVIDIA NIM, OpenAI-compatible) ---
# Get free keys at https://build.nvidia.com (format: nvapi-...). Each free key is ~40 req/min;
# add 2+ and the server round-robins + fails over between them automatically.
NVIDIA_NIM_API_KEY_1=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_API_KEY_2=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: NVIDIA_NIM_API_KEY_3=...
# Model id from build.nvidia.com. 8B = lowest latency (recommended); 70B = more nuanced/slower.
CHAT_MODEL=meta/llama-3.1-8b-instruct

# --- Contact form (Resend) ---
# Get a key at https://resend.com  (format: re_...)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Where contact-form messages are emailed:
CONTACT_TO=hariharanjoga445@gmail.com
# "From" address. Until you verify your own domain in Resend, use their shared test sender:
CONTACT_FROM=Portfolio <onboarding@resend.dev>

# --- Voice pipeline: ElevenLabs Scribe STT -> NVIDIA -> ElevenLabs Flash v2.5 TTS ---
ELEVEN_API_KEY=
ELEVEN_MODEL=eleven_flash_v2_5
ELEVEN_STT_MODEL=scribe_v1
# Voice for the bot — grab a Voice ID from https://elevenlabs.io/app/voice-library
VOICE_ID=
# Optional: only needed if you later route Hindi/Telugu voice-out through Sarvam Bulbul
SARVAM_API_KEY=
